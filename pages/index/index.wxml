<view class="indexContainer">
  <!-- 轮播图板块 -->
  <view class="bannersBox">
    <swiper class="banners" indicator-dots indicator-color="rgba(0,0,0,0.3)" indicator-active-color="#d43c33" autoplay interval='3000'>
      <swiper-item wx:for="{{banners}}" wx:key="bannersId">
        <image src="{{item.pic}}"></image>
      </swiper-item>
    </swiper>
  </view>

  

  <!-- 图标导航栏区域 -->
  <view class="navcontainer">
    <view class="navItem" catchtap="toRecommendSong">
      <text class="iconfont icon-rili"></text>
      <text>每日推荐</text>
    </view>
    <view class="navItem">
      <text class="iconfont icon-paihangbang"></text>
      <text>排行榜</text>
    </view>
    <view class="navItem">
      <text class="iconfont icon-diantai"></text>
      <text>电台</text>
    </view>
    <view class="navItem">
      <text class="iconfont icon-shoucanggedan"></text>
      <text>歌单</text>
    </view>
    <view class="navItem">
      <text class="iconfont icon-zhibo"></text>
      <text>直播</text>
    </view>
  </view>

  <!-- 推荐歌曲 -->
  <view class="recommendContainer">
    <NavHeader title="推荐歌曲" header="为你精心推荐"/>
  </view>

  <scroll-view class="recommendScroll" enhanced="true" enable-flex scroll-x>
    <view class="scrollItem" wx:for="{{personalized}}"  wx:key="id">
      <image src="{{item.picUrl}}"></image>
      <text>{{item.name}}</text>
    </view>
  </scroll-view>
<!-- 排行榜区域 -->
  <view class="topList">
    <NavHeader title="排行榜" header="热歌风向标"/>
    <swiper class="toplistSwiper" next-margin="60rpx">
        <swiper-item wx:for="{{toplist}}" wx:key="name">
          <view class="swiperItem">
          <view class="title">{{item.name}}</view>
          <view class="musicItem" wx:for="{{item.tracks}}" wx:for-index="idx" wx:for-item="tracksName" wx:key="id">
            <image src="{{tracksName.al.picUrl}}"></image>
            <text class="count">{{idx + 1}}</text>
            <text class="musicName">{{tracksName.al.name}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>
</view>