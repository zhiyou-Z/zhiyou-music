/* 轮播图 */
.bannersBox{
  /* padding: 20rpx; */
  border-radius: 10px;
}
.banners{
  width: 100%;
  height: 320rpx;
}
.banners swiper-item{
  padding: 20rpx 20rpx 0 20rpx;
  -webkit-box-sizing: border-box;
  -moz-box-sizing: border-box;
  box-sizing: border-box;
  overflow: hidden;
}
.banners image{
  border-radius: 10px;
  width: 100%;
  height: 100%;
}
/* 图标导航栏 */
.navcontainer{
  display: flex;
}

.navItem{
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
}

.navItem .iconfont{
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 100rpx;
  background-color: rgb(240, 19, 19);
  font-size: 50rpx;
  color:#fff;
  margin: 20rpx 0;
}
.navItem text{
  font-size: 26rpx;
}

/* 推荐歌曲 */
.recommendContainer{
  padding: 20rpx;
}
.recommendContainer .remHeader .remTitle{
  font-size: 32rpx;
  line-height: 80rpx;
  color: #666;
}
.recommendContainer .remHeader .more{
  float: right;
  border: 1px solid #333;
  font-size: 26rpx;
  padding: 0 8px;
  border-radius: 30rpx;
}
 .recommendScroll{
   display: flex;
   height: 300rpx;
 }
 .scrollItem{
   width: 200rpx;
   margin-left: 20rpx;
 }
 .scrollItem image{
   width: 200rpx;
   height: 200rpx;
   border-radius: 10rpx;
 }
 .scrollItem text{
   font-size: 26rpx;
   /* 多行文本打点处理 */
   overflow: hidden;
   text-overflow: ellipsis;
   display: -webkit-box;
   -webkit-box-orient: vertical;
   -webkit-line-clamp: 2;
 }
/* 排行榜区域*/
 .topList{
   padding: 10rpx 20rpx;
 }

.toplistSwiper{
  height: 400rpx;
  padding: 20rpx 0;
}
.swiperItem{
  padding: 10rpx;
}
.swiperItem title{
  padding: 20rpx;
  font-size: 26rpx;
  line-height: 80rpx;
}
.musicItem{
  display: flex;
  margin-bottom: 14rpx;
  margin-top: 8rpx;
  background-color: rgba(238, 238, 238, 0.1);
}
.musicItem image{
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
}
.musicItem .count{
  width: 60rpx;
  height: 100rpx;
  text-align: center;
  line-height: 100rpx;
}
.musicItem .musicName{
  height: 100rpx;
  text-align: center;
  line-height: 100rpx;
  max-width: 400rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.swiperItem{
  width: 96%;
  border-radius: 20rpx;
  background-color: rgba(237, 237, 237, 0.3);
}