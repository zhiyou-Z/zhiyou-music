.songDetailContainer{
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}
/* 背景图片 */
.backView{
  filter: blur(10px);
  transform: scale(1.2);
  z-index: -1;
  position: absolute;
  top: 0;
  width: 750rpx;
  height: 100vh;
  background: rebeccapurple;
}
.blackImage{
  position: absolute;
  top: 0px;
  bottom: 0px;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.musicImg{
  z-index:inherit;
  margin-top: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.musicImg image{
  box-shadow: 1px 0 4px 1px #ccc;
  width: 600rpx;
  height: 600rpx;
  border-radius: 20rpx;
}
.songDetailText{
  display: flex;
  flex-direction: column;
  padding: 40rpx 70rpx;
  position: relative;
}
.songDetailText .left{
  position: absolute;
  right: 70rpx;
  top: 100rpx;
  font-size: 50rpx;
  color: rgb(212, 60, 51);
}
.songDetailText .songTitle{
  font-size: 40rpx;
  /* width: 300rpx; */
  max-width: 600rpx;
  line-height: 100rpx;
  height: 100rpx;
  color: #fff;
  font-weight: 600;
}
.songDetailText .author{
  color: #eff;
}

.musicControl{
  width: 100%;
  position: absolute;
  bottom: 60rpx;
  left: 0;
  display: flex;
}
.musicControl text{
  width: 20%;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  color: #fff;
  font-size: 50rpx;
}
.musicControl .big{
  font-size: 70rpx;
}

/* 进度条 */
.progressControl{
  width: 640rpx;
  height: 80rpx;
  bottom: 200rpx;
  position: absolute;
  line-height: 80rpx;
  display: flex;
  left: 40rpx;
}
.progressControl slider{
  width: 640rpx;
}

.progressControl text{
  color: #f5f5f5;
} 